<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<!-- Custom Cursor JS -->
<script>
  (function () {

    // Force inject cursor:none as highest priority
    const style = document.createElement('style');
    style.innerHTML = `
      html, body, *, *::before, *::after,
      a, a:hover, a:focus, a:active,
      button, button:hover,
      input, textarea, select,
      label, [role="button"],
      .btn, .btn:hover,
      .nav-link, .dropdown-item,
      [class*="btn"],
      .ynav-btn, .ynav-hamburger,
      .ynav-menu a, .ynav-drawer-nav a {
        cursor: none !important;
      }
    `;
    document.head.appendChild(style);
    document.documentElement.style.setProperty('cursor', 'none', 'important');
    document.body.style.setProperty('cursor', 'none', 'important');

    // Prevent double init
    if (window.__cursorInit) return;
    window.__cursorInit = true;

    const cursor = document.getElementById('cursor');
    const follow = document.getElementById('cursorFollow');

    if (!cursor || !follow) return;

    // ✅ Start off screen — no stuck ring at top-left
    let mouseX = -100, mouseY = -100;
    let followX = -100, followY = -100;

    // Dot snaps instantly to mouse
    document.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      cursor.style.left = mouseX + 'px';
      cursor.style.top  = mouseY + 'px';
    });

    // Ring follows with smooth lag
    function animateFollow() {
      followX += (mouseX - followX) * 0.12;
      followY += (mouseY - followY) * 0.12;
      follow.style.left = followX + 'px';
      follow.style.top  = followY + 'px';
      requestAnimationFrame(animateFollow);
    }
    animateFollow();

    // Hover expand — works on navbar, buttons, links, everything
    document.addEventListener('mouseover', (e) => {
      if (e.target.closest('a, button, [role="button"], input, textarea, select, label, .ynav-btn, .ynav-hamburger')) {
        cursor.classList.add('hover');
        follow.classList.add('hover');
      }
    });

    document.addEventListener('mouseout', (e) => {
      if (e.target.closest('a, button, [role="button"], input, textarea, select, label, .ynav-btn, .ynav-hamburger')) {
        cursor.classList.remove('hover');
        follow.classList.remove('hover');
      }
    });

    // Hide when mouse leaves browser window
    document.addEventListener('mouseleave', () => {
      cursor.style.opacity = '0';
      follow.style.opacity = '0';
    });

    document.addEventListener('mouseenter', () => {
      cursor.style.opacity = '1';
      follow.style.opacity = '0.5';
    });

  })();
</script>

</body>
</html>