<style>
  :root {
    --lime:  #C8F135;
    --dark:  #0C0F14;
    --dark3: #1a2030;
    --white: #FFFFFF;
    --gray:  #8a9bb0;
    --card:  #141b26;
    --nav-h: 72px;
  }

  /* ========================= NAVBAR ========================= */
  .ynav-wrap {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: var(--nav-h);
    z-index: 99999;
    padding: 0 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(12, 15, 20, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(200, 241, 53, 0.08);
    transition: background 0.4s, border-color 0.4s;
  }

  .ynav-wrap.scrolled {
    background: rgba(12, 15, 20, 0.97);
    border-color: rgba(200, 241, 53, 0.14);
  }

  /* ---- Brand ---- */
  .ynav-brand {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    letter-spacing: 2px;
    color: var(--white);
    text-decoration: none;
    flex-shrink: 0;
    transition: opacity 0.2s;
  }

  .ynav-brand:hover { opacity: 0.85; }
  .ynav-brand span  { color: var(--lime); }

  /* ---- Center menu ---- */
  .ynav-menu {
    display: flex;
    gap: 36px;
    list-style: none;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  .ynav-menu a {
    font-family: 'Syne', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--gray);
    text-decoration: none;
    position: relative;
    transition: color 0.3s;
  }

  .ynav-menu a::after {
    content: '';
    position: absolute;
    bottom: -4px; left: 0;
    width: 0; height: 1px;
    background: var(--lime);
    transition: width 0.3s ease;
  }

  .ynav-menu a:hover        { color: var(--white); }
  .ynav-menu a:hover::after { width: 100%; }
  .ynav-menu a.active        { color: var(--white); }
  .ynav-menu a.active::after { width: 100%; }

  /* ---- Right actions ---- */
  .ynav-actions {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }

  .ynav-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 10px 22px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    border-radius: 40px;
    transition: background 0.3s, color 0.3s, transform 0.2s;
    white-space: nowrap;
  }

  .ynav-btn--primary {
    background: var(--lime);
    color: var(--dark);
  }

  .ynav-btn--primary:hover {
    background: var(--white);
    color: var(--dark);
    transform: translateY(-1px);
  }

  .ynav-btn--ghost {
    background: transparent;
    color: var(--lime);
    border: 1px solid rgba(200, 241, 53, 0.35);
  }

  .ynav-btn--ghost:hover {
    background: var(--lime);
    color: var(--dark);
    transform: translateY(-1px);
  }

  .ynav-btn--logout {
    background: transparent;
    color: var(--gray);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .ynav-btn--logout:hover {
    background: #ff4d4d;
    color: var(--white);
    border-color: #ff4d4d;
    transform: translateY(-1px);
  }


  /* ========================= HAMBURGER ========================= */
  .ynav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 4px;
    background: none;
    border: none;
  }

  .ynav-hamburger span {
    display: block;
    width: 22px; height: 2px;
    background: var(--white);
    border-radius: 2px;
    transition: all 0.3s;
  }

  /* ========================= MOBILE DRAWER ========================= */
  .ynav-drawer {
    display: none;
    position: fixed;
    top: var(--nav-h);
    left: 0; right: 0;
    background: rgba(12, 15, 20, 0.98);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(200, 241, 53, 0.1);
    padding: 24px 24px 32px;
    z-index: 99998;
    flex-direction: column;
    gap: 4px;
  }

  .ynav-drawer.open { display: flex; }

  .ynav-drawer a {
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gray);
    text-decoration: none;
    padding: 14px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    transition: color 0.3s;
  }

  .ynav-drawer a:last-child { border-bottom: none; }
  .ynav-drawer a:hover      { color: var(--lime); }

  .ynav-drawer-actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 20px;
  }

  /* ========================= RESPONSIVE ========================= */
  @media (max-width: 1024px) {
    .ynav-wrap      { padding: 0 32px; }
    .ynav-menu      { display: none; }
    .ynav-actions   { display: none; }
    .ynav-hamburger { display: flex; }
  }

  @media (max-width: 640px) {
    .ynav-wrap { padding: 0 20px; }
  }
</style>

<nav class="ynav-wrap" id="ynav">

  <!-- Brand -->
  <a class="ynav-brand" href="/">Ya.<span>Showtimestudio</span></a>

  <!-- Center links -->
  <ul class="ynav-menu">
    <li><a href="/">Home</a></li>
    <li><a href="/about">About</a></li>
    <li><a href="/services">Services</a></li>
    <li><a href="/portfolio">Portfolio</a></li>
    <li><a href="/review">Reviews</a></li>
    <li><a href="/contact">Contact</a></li>
    <%# Admin-only nav link %>
    <% if (user && user.role === 'admin') { %>
      <li><a href="/admin/contacts" class="admin-link">⚙ Contacts</a></li>
    <% } %>
  </ul>

  <!-- Right actions -->
  <div class="ynav-actions">
    <% if (user) { %>

      <a href="/contact" class="ynav-btn ynav-btn--primary">Start a Project</a>
      <a href="/logout"  class="ynav-btn ynav-btn--logout">Log Out</a>

    <% } else { %>
      <a href="/signin" class="ynav-btn ynav-btn--ghost">Sign In</a>
      <a href="/signup" class="ynav-btn ynav-btn--primary">Sign Up</a>
    <% } %>
  </div>

  <!-- Hamburger (mobile) -->
  <button class="ynav-hamburger" id="ynav-hamburger" aria-label="Toggle menu">
    <span></span><span></span><span></span>
  </button>

</nav>

<!-- Mobile drawer -->
<div class="ynav-drawer" id="ynav-drawer">
  <a href="/">Home</a>
  <a href="/about">About</a>
  <a href="/services">Services</a>
  <a href="/portfolio">Portfolio</a>
  <a href="/review">Reviews</a>
  <a href="/contact">Contact</a>
  <%# Admin-only drawer link %>
  <% if (user && user.role === 'admin') { %>
    <a href="/admin/contacts" class="admin-link">Requests</a>
  <% } %>

  <div class="ynav-drawer-actions">
    <% if (user) { %>
      <a href="/contact" class="ynav-btn ynav-btn--primary">Start a Project</a>
      <a href="/logout"  class="ynav-btn ynav-btn--logout">Log Out</a>
    <% } else { %>
      <a href="/signin" class="ynav-btn ynav-btn--ghost">Sign In</a>
      <a href="/signup" class="ynav-btn ynav-btn--primary">Sign Up</a>
    <% } %>
  </div>
</div>

<script>
  // Scroll effect
  const ynav = document.getElementById('ynav');
  window.addEventListener('scroll', function () {
    ynav.classList.toggle('scrolled', window.scrollY > 10);
  }, { passive: true });

  // Hamburger toggle
  const hamburger = document.getElementById('ynav-hamburger');
  const drawer    = document.getElementById('ynav-drawer');

  hamburger.addEventListener('click', function () {
    drawer.classList.toggle('open');
  });

  // Close drawer on link click
  drawer.querySelectorAll('a').forEach(function (a) {
    a.addEventListener('click', function () {
      drawer.classList.remove('open');
    });
  });

  // Active link highlight
  document.querySelectorAll('.ynav-menu a').forEach(function (link) {
    if (link.getAttribute('href') === window.location.pathname) {
      link.classList.add('active');
    }
  });
</script>